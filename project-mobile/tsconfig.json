{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",

    // ← baseUrl "." makes "src" the root for all relative imports 
    "baseUrl": ".",

    // ← only needed if you want alias imports.
    // You can remove this section if you stick to relative paths (../components/...)
    "paths": {
      "@components/*": ["src/components/*"],
      "@context/*":    ["src/context/*"]
    }
  },
  "include": [
    "src/**/*",    // ← make sure TS actually scans all your .ts/.tsx under src

  ]
}
