{
  "cli": { "appVersionSource": "remote" },
  "build": {
    "development": { "environment": "development", "node": "18.18.2" },
    "preview":      { "environment": "preview",      "node": "18.18.2" },
    "production":   { "environment": "production",   "node": "18.18.2" },
    "my-profile":   { "environment": "production",   "node": "18.18.2" }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "env:ASC_APP_ID",            
        "ascApiKeyId": "env:ASC_KEY_ID",
        "ascApiKeyIssuerId": "env:ASC_ISSUER_ID",
        "ascApiKeyPath": "env:EXPO_ASC_API_KEY_PATH",
        "appleTeamId": "env:APPLE_TEAM_ID"
      }
    }
  }
}
